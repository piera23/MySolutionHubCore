@using MudBlazor
@using Web.Services
@inject AuthStateService AuthState
@inject ApiHttpClient ApiClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Home">
        Home / Feed
    </MudNavLink>

    <MudNavLink Href="/chat"
                Icon="@Icons.Material.Filled.Chat">
        Messaggi
    </MudNavLink>

    <MudNavLink Href="/notifications"
                Icon="@Icons.Material.Filled.Notifications">
        Notifiche
    </MudNavLink>

    <MudNavLink Href="/profile"
                Icon="@Icons.Material.Filled.Person">
        Profilo
    </MudNavLink>

    <MudDivider Class="my-2" />

    <MudNavGroup Title="Admin" Icon="@Icons.Material.Filled.AdminPanelSettings"
                 Expanded="false">
        <MudNavLink Href="/admin/stats"
                    Icon="@Icons.Material.Filled.BarChart">
            Dashboard
        </MudNavLink>
        <MudNavLink Href="/admin/tenants"
                    Icon="@Icons.Material.Filled.Business">
            Tenant
        </MudNavLink>
    </MudNavGroup>

    <MudDivider Class="my-2" />

    @if (AuthState.IsAuthenticated)
    {
        <MudNavLink Icon="@Icons.Material.Filled.Logout"
                    OnClick="HandleLogout">
            Esci
        </MudNavLink>
    }
    else
    {
        <MudNavLink Href="/register"
                    Icon="@Icons.Material.Filled.PersonAdd"
                    Match="NavLinkMatch.All">
            Registrati
        </MudNavLink>
    }
</MudNavMenu>

@code {
    private async Task HandleLogout()
    {
        try
        {
            if (!string.IsNullOrEmpty(AuthState.RefreshToken))
            {
                var http = ApiClient.GetClient();
                await http.PostAsJsonAsync("api/auth/logout", new { refreshToken = AuthState.RefreshToken });
            }
        }
        catch { }
        finally
        {
            await AuthState.LogoutAsync();
            Nav.NavigateTo("/login");
        }
    }
}

