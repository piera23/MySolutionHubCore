@page "/reset-password"
@rendermode InteractiveServer
@using MudBlazor
@inject ApiHttpClient ApiClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Reset Password</PageTitle>

<div style="min-height:100vh;background:linear-gradient(135deg,#1e3a5f 0%,#2563EB 100%);display:flex;align-items:center;justify-content:center;padding:16px">
    <MudPaper Elevation="4" Class="pa-8 rounded-xl" Style="width:100%;max-width:440px">

        <div class="text-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.Lock"
                     Style="font-size:3rem;color:#2563EB" />
            <MudText Typo="Typo.h5" Style="font-weight:700;margin-top:8px">
                Nuova Password
            </MudText>
        </div>

        @if (_invalidLink)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">
                Il link non è valido o è scaduto. Richiedi un nuovo reset.
            </MudAlert>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       FullWidth="true" Href="/forgot-password">
                Richiedi nuovo link
            </MudButton>
        }
        else if (_done)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                Password aggiornata con successo!
            </MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true" Href="/login" Style="font-weight:700">
                Vai al Login
            </MudButton>
        }
        else
        {
            <MudTextField @bind-Value="_newPassword"
                          Label="Nuova Password *"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          InputType="@(_showPwd ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPwd ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="() => _showPwd = !_showPwd"
                          HelperText="Minimo 8 caratteri, una maiuscola, un numero"
                          Class="mb-3" />

            <MudTextField @bind-Value="_confirmPassword"
                          Label="Conferma Password *"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          InputType="@(_showConfirm ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showConfirm ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="() => _showConfirm = !_showConfirm"
                          Class="mb-4" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleReset"
                       Disabled="_loading"
                       Style="font-weight:700;height:48px">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Salva nuova password
            </MudButton>
        }

    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery] private int UserId { get; set; }
    [SupplyParameterFromQuery] private string Token { get; set; } = "";

    private string _newPassword = "";
    private string _confirmPassword = "";
    private bool _showPwd = false;
    private bool _showConfirm = false;
    private bool _loading = false;
    private bool _done = false;
    private bool _invalidLink = false;

    protected override void OnInitialized()
    {
        if (UserId <= 0 || string.IsNullOrWhiteSpace(Token))
            _invalidLink = true;
    }

    private async Task HandleReset()
    {
        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 8)
        {
            Snackbar.Add("La password deve avere almeno 8 caratteri.", Severity.Warning);
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add("Le password non coincidono.", Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            var http = ApiClient.GetClient();
            var response = await http.PostAsJsonAsync("api/auth/reset-password", new
            {
                userId = UserId,
                token = Token,
                newPassword = _newPassword
            });

            if (response.IsSuccessStatusCode)
            {
                _done = true;
            }
            else
            {
                _invalidLink = true;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore di connessione: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
