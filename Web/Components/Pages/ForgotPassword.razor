@page "/forgot-password"
@rendermode InteractiveServer
@using MudBlazor
@inject ApiHttpClient ApiClient
@inject ISnackbar Snackbar

<PageTitle>Password dimenticata</PageTitle>

<div style="min-height:100vh;background:linear-gradient(135deg,#1e3a5f 0%,#2563EB 100%);display:flex;align-items:center;justify-content:center;padding:16px">
    <MudPaper Elevation="4" Class="pa-8 rounded-xl" Style="width:100%;max-width:440px">

        <div class="text-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.LockReset"
                     Style="font-size:3rem;color:#2563EB" />
            <MudText Typo="Typo.h5" Style="font-weight:700;margin-top:8px">
                Password dimenticata
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Inserisci la tua email per ricevere il link di reset.
            </MudText>
        </div>

        @if (_sent)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                Se l'email è associata a un account, riceverai un link entro pochi minuti.
            </MudAlert>
            <div class="text-center">
                <MudLink Href="/login" Color="Color.Primary" Style="font-weight:600">
                    Torna al Login
                </MudLink>
            </div>
        }
        else
        {
            <MudTextField @bind-Value="_email"
                          Label="Email"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          InputType="InputType.Email"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          Class="mb-4" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleSubmit"
                       Disabled="_loading"
                       Style="font-weight:700;height:48px">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Invia link di reset
            </MudButton>

            <div class="text-center mt-4">
                <MudLink Href="/login" Color="Color.Primary">
                    Torna al Login
                </MudLink>
            </div>
        }

    </MudPaper>
</div>

@code {
    private string _email = "";
    private bool _loading = false;
    private bool _sent = false;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_email))
        {
            Snackbar.Add("Inserisci la tua email.", Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            var http = ApiClient.GetClient();
            await http.PostAsJsonAsync("api/auth/forgot-password", new { email = _email });
            // Mostriamo sempre successo (anti-enumeration)
            _sent = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore di connessione: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
